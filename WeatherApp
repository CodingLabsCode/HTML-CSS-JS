<!DOCTYPE html>
<html>
    <head>
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    </head>
    <body class="h-screen flex justify-center items-center 
            [background-image:linear-gradient(rgba(255,255,255,0.15)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.15)_1px,transparent_1px)]
            bg-[rgb(33,33,33)]  
            bg-[length:40px_40px] text-white">

        <main class="flex  items-center flex-col shadow-2xl 
                bg-[rgb(33,33,33)] justify-center p-13 border 
                rounded-lg w-125 items-start">
            <div>
                <h1 class="font-bold text-3xl">Weather app </h1>
                <p class="font-semibold text-xl">Enter a city to get started</p>
            </div>

            <div class="flex flex-col mt-3 shadow-2xl">
                <label class="text-xl fontsemibold mb-1" for="weather">Enter city</label>
                <input class="border rounded-lg p-4
                        hover:scale-95 transition focus:scale-105 
                        placeholder:text-white w-106" 
                        id="userinput" type="text" placeholder="e.g London">
            </div>

            <div class="flex flex-col items-center w-full mt-5">
                <button class="border p-3 w-50 bg-blue-600 border-[rgb(33,33,33)]
                        active:scale-105 hover:scale-95 shadow-2xl shadow-blue-500
                        w-full text-blue-300 hover:blue-500"
                        id="btn">Get weather</button>
            </div>

            <div class="flex flex-col items-center w-full mt-4">
                <button class="border p-3 w-50 bg-red-600 border-[rgb(33,33,33)]
                        active:scale-105 hover:scale-95 shadow-2xl shadow-red-500
                        mb-10 w-full text-red-300 hover:red-500"
                        id="resetbtn">Reset</button>
            </div>

            <hr class="border w-full mb-4">

            <div class="flex w-100 justify-center">
                <hr>
                <h1 class="font-semibold text-2xl" id="errorText">Weather</h1>
            </div>

            <div class="flex flex-col">
                <p class="font-semibold text-xl mb-2" id="city">City:</p>
                <p class="font-semibold text-xl mb-2" id="temp">Temp:</p>
                <p class="font-semibold text-xl mb-2" id="condtions">Condtions:</p>
            </div>
            
        </main>
        <script src="script.js"></script>
    </body>
</html>
